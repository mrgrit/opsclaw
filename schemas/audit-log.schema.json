{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AuditLog",
  "type": "object",
  "required": ["timestamp", "actor", "role", "action", "decision"],
  "properties": {
    "timestamp": {"type": "string", "format": "date-time"},
    "actor": {"type": "string"},
    "role": {"type": "string"},
    "action": {"type": "string"},
    "decision": {"type": "string", "enum": ["allow", "transform", "block", "approve", "deny"]},
    "policy_id": {"type": "string"},
    "prompt_hash": {"type": "string"}
  },
  "additionalProperties": true
}
