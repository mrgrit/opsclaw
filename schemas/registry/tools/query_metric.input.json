{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "query_metric input",
  "type": "object",
  "properties": {
    "metric_name": {"type": "string"},
    "time_range": {
      "type": "object",
      "properties": {
        "start": {"type": "string", "format": "date-time"},
        "end": {"type": "string", "format": "date-time"}
      },
      "required": ["start", "end"]
    }
  },
  "required": ["metric_name", "time_range"]
}
