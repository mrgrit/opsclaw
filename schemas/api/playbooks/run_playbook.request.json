  "type": "object",
  "required": ["playbook_id", "asset_scope"],
  "properties": {
    "playbook_id": {"type": "string"},
    "asset_scope": {"type": "array", "items": {"type": "string"}},
    "inputs": {"type": "object"}
  }
}
