# Environment variables example
# DATABASE_URL=postgresql://oldclaw:password@localhost:5432/oldclaw

# pi adapter settings (M1)
OLDCLAW_PI_PROVIDER=ollama
OLDCLAW_PI_BASE_URL=http://211.170.162.139:10534/v1
OLDCLAW_PI_API_KEY=ollama
OLDCLAW_PI_MANAGER_MODEL=gpt-oss:120b
OLDCLAW_PI_MASTER_MODEL=gpt-oss:120b
OLDCLAW_PI_SUBAGENT_MODEL=gpt-oss:120b
OLDCLAW_PI_DEFAULT_TIMEOUT_S=120
OLDCLAW_PI_SESSION_MODE=service
OLDCLAW_PI_COMMAND=pi
OLDCLAW_PI_WORKING_DIR=

# local postgres settings (M2 preflight)
DATABASE_URL=postgresql://oldclaw:oldclaw@127.0.0.1:5432/oldclaw
POSTGRES_DB=oldclaw
POSTGRES_USER=oldclaw
POSTGRES_PASSWORD=oldclaw
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
