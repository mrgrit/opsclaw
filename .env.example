# Environment variables example
# DATABASE_URL=postgresql://opsclaw:password@localhost:5432/opsclaw

# pi adapter settings (M1)
OPSCLAW_PI_PROVIDER=ollama
OPSCLAW_PI_BASE_URL=http://localhost:11434/v1
OPSCLAW_PI_API_KEY=ollama
OPSCLAW_PI_MANAGER_MODEL=gpt-oss:120b
OPSCLAW_PI_MASTER_MODEL=gpt-oss:120b
OPSCLAW_PI_SUBAGENT_MODEL=gpt-oss:120b
OPSCLAW_PI_DEFAULT_TIMEOUT_S=120
OPSCLAW_PI_SESSION_MODE=service
OPSCLAW_PI_COMMAND=pi
OPSCLAW_PI_WORKING_DIR=

# notification: slack channel config (JSON, stored in notification_channels.config)
# {"bot_token": "xoxb-...", "channel": "#ops-alerts"}

# notification: email channel config (JSON, stored in notification_channels.config)
# {"smtp_host": "smtp.example.com", "smtp_port": 587, "use_tls": true,
#  "username": "opsclaw@example.com", "password": "...",
#  "from_addr": "opsclaw@example.com", "to_addrs": ["admin@example.com"]}

# local postgres settings (M2 preflight)
DATABASE_URL=postgresql://opsclaw:opsclaw@127.0.0.1:5432/opsclaw
POSTGRES_DB=opsclaw
POSTGRES_USER=opsclaw
POSTGRES_PASSWORD=opsclaw
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
