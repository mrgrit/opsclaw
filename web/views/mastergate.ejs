<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <title>OpsClaw MasterGate</title>
  <style>
    body { font-family: system-ui, sans-serif; margin: 24px; }
    .row { display: flex; gap: 16px; align-items: flex-start; }
    .card { border: 1px solid #ddd; border-radius: 10px; padding: 16px; flex: 1; background:#fff; }
    textarea { width: 100%; height: 120px; }
    input[type=text], input[type=number] { width: 100%; padding: 8px; }
    select { padding: 8px; }
    button { padding: 8px 12px; }
    pre { background: #f7f7f7; padding: 12px; border-radius: 8px; overflow: auto; max-height: 420px; }
    a { text-decoration: none; }
    .muted { color: #666; }
    .tag { display:inline-block; padding:2px 8px; border-radius:999px; border:1px solid #ccc; margin-left:6px; font-size:12px; }
    .ok { border-color:#0a0; }
    .warn { border-color:#aa0; }
    .bad { border-color:#a00; }
    .btnrow { display:flex; gap:10px; align-items:flex-end; margin:10px 0; flex-wrap: wrap; }
    label { font-size: 12px; color:#444; }
    .two { display:grid; grid-template-columns: 1fr 1fr; gap: 10px; width: 100%; }
    .small { font-size:12px; }
    .statusbar { margin: 10px 0 16px; display:flex; gap:8px; align-items:center; flex-wrap: wrap; }
    .queue-controls { display:flex; gap:10px; align-items:flex-end; margin: 10px 0 10px; flex-wrap: wrap; }
    .queue-controls > div { min-width: 160px; }
    .queue { margin: 10px 0 0; padding-left: 18px; }
    .queue li { margin: 8px 0; }
    .queue .meta { margin-left:8px; font-size:12px; color:#666; }
    .pill { display:inline-block; padding:6px 10px; border-radius:10px; border:1px solid #ddd; background:#fafafa; }
    details > summary { cursor:pointer; user-select:none; }
    .summary-card { border:1px solid #eee; background:#fcfcfc; border-radius:10px; padding:12px; margin: 10px 0; }
    .summary-row { display:flex; gap:10px; flex-wrap:wrap; align-items:center; }
    .right { flex: 0 0 520px; max-width: 520px; }
    .qline { display:flex; gap:8px; align-items:center; flex-wrap: wrap; }
    .qline .grow { flex:1; min-width: 240px; }
    .chk { transform: scale(1.1); }
    @media (max-width: 1100px){
      .row { flex-direction: column; }
      .right { flex: 1; max-width: none; }
    }
  </style>
</head>
<body>
  <h1>MasterGate</h1>

  <div class="summary-card" style="margin: 10px 0 14px;">
    <div class="summary-row" style="align-items:flex-end;">
      <div class="grow" style="min-width:260px;">
        <label>API Token (stored locally)</label>
        <input id="authToken" type="text" placeholder="x-opsclaw-token" />
      </div>
      <div style="min-width:180px;">
        <label>Actor (optional)</label>
        <input id="authActor" type="text" placeholder="e.g. admin" />
      </div>
      <div>
        <button type="button" id="authSave">Save</button>
        <button type="button" id="authClear">Clear</button>
      </div>
      <div class="muted small" id="authStatus" style="min-width:220px;"></div>
    </div>
    <div class="muted small" style="margin-top:6px;">
      When tokens are enabled on the API, the web UI must send <code>x-opsclaw-token</code>.
      This page stores it in <b>localStorage</b> and also sets a cookie so server-rendered forms work.
    </div>
  </div>

  <p class="muted">API: <%= api %> | <a href="/">Home</a></p>

  <div class="statusbar">
    <% if (settings && settings.error) { %>
      <span class="tag bad">settings: error</span>
      <span class="muted"><%= settings.error %></span>
    <% } else { %>
      <% const o = settings?.ollama; const oa = settings?.openai; const an = settings?.anthropic; %>

      <% if (o && o.configured && o.ok) { %>
        <span class="tag ok">ollama: OK</span>
      <% } else if (o && o.configured && !o.ok) { %>
        <span class="tag bad">ollama: FAIL</span>
        <span class="muted"><%= o.error %></span>
      <% } else { %>
        <span class="tag warn">ollama: not configured</span>
      <% } %>

      <% if (oa && oa.configured) { %>
        <span class="tag ok">openai key: set</span>
      <% } else { %>
        <span class="tag warn">openai key: empty</span>
      <% } %>

      <% if (an && an.configured) { %>
        <span class="tag ok">anthropic key: set</span>
      <% } else { %>
        <span class="tag warn">anthropic key: empty</span>
      <% } %>
    <% } %>
  </div>

  <% if (error) { %>
    <div class="card" style="border-color:#c00;">
      <b>Error</b>
      <pre><%= error %></pre>
    </div>
  <% } %>

  <div class="row">
    <div class="card">
      <h3>1) Create MasterGate Request (approval required)</h3>
      <form method="post" action="/mastergate/request">
        <label>Title</label>
        <input type="text" name="title" value="Ask Master" />

        <label>Draft Prompt</label>
        <textarea name="draft_prompt">Explain root-cause candidates and verification commands for the issue.</textarea>

        <label>Context Snippets</label>
        <textarea name="context_snippets">Include only minimal error lines here.</textarea>

        <p><button type="submit">Submit for Approval</button></p>
      </form>

      <% if (created) { %>
        <h4>Created</h4>
        <details open>
          <summary class="muted">Show JSON</summary>
          <pre><%= JSON.stringify(created, null, 2) %></pre>
        </details>
      <% } %>
    </div>

    <div class="card right">
      <h3>2) Approval Queue</h3>
      <div class="muted">Filter / search / sort + bulk select + quick ZIP</div>

      <div class="queue-controls">
        <div>
          <label>Status</label><br/>
          <select id="qStatus">
            <option value="ALL">ALL</option>
            <option value="PENDING">PENDING</option>
            <option value="APPROVED">APPROVED</option>
            <option value="REJECTED">REJECTED</option>
          </select>
        </div>

        <div>
          <label>Sort</label><br/>
          <select id="qSort">
            <option value="PENDING_FIRST">PENDING first</option>
            <option value="NEWEST">Newest</option>
            <option value="OLDEST">Oldest</option>
            <option value="TITLE">Title</option>
          </select>
        </div>

        <div class="grow">
          <label>Search (title / id)</label><br/>
          <input id="qSearch" type="text" placeholder="e.g. strict-json / 857e3c72" />
        </div>

        <div>
          <button type="button" id="qReset">Reset</button>
        </div>
      </div>

      <div class="summary-row" style="margin: 6px 0 2px;">
        <span class="pill"><b>PENDING</b>: <span class="muted" id="pendingCount">0</span></span>
        <button type="button" id="btnPendingOnly">PENDING only</button>
        <button type="button" id="btnNewest">Newest</button>
        <span class="pill"><b>Selected</b>: <span class="muted" id="selCount">0</span></span>
        <button type="button" id="btnSelectVisible">Select visible</button>
        <button type="button" id="btnClearSel">Clear</button>
      </div>

      <div class="summary-card" style="margin-top:10px;">
        <div class="summary-row">
          <input id="bulkActor" type="text" value="admin" style="min-width:140px;" />
          <input id="bulkReason" type="text" placeholder="reason (optional)" style="min-width:260px; flex:1;" />
          <button type="button" id="btnBulkApprove">Approve selected</button>
          <button type="button" id="btnBulkReject">Reject selected</button>
        </div>
        <div class="muted small" id="bulkMsg"></div>
      </div>

      <div class="muted small" id="qCount"></div>

      <ul class="queue" id="approvalList">
        <% approvals.forEach(a => { %>
          <%
            const st = a.decision_state || "PENDING";
            const gate = a.gate?.decision || "";
            const cls = gate === "BLOCK" ? "bad" : (gate === "TRANSFORM" ? "warn" : "ok");
            const createdAt = a.created_at || "";
          %>
          <li
            data-id="<%= a.approval_id %>"
            data-title="<%= (a.title || '').toLowerCase() %>"
            data-status="<%= st %>"
            data-created="<%= createdAt %>"
          >
            <div class="qline">
              <input type="checkbox" class="qPick chk" value="<%= a.approval_id %>" />

              <a href="/approvals/<%= a.approval_id %>">
                <%= a.title %>
                <% if (createdAt) { %>
                  <span class="meta"><%= createdAt %></span>
                <% } %>
                <span class="tag <%= cls %>"><%= gate %></span>
                <span class="tag"><%= st %></span>
              </a>

              <a href="/approvals/<%= a.approval_id %>/evidence.zip" target="_blank" rel="noopener">
                <span class="tag">ZIP</span>
              </a>
            </div>
          </li>
        <% }) %>
      </ul>
    </div>
  </div>

  <div class="card" style="margin-top:16px;">
    <h3>3) Selected Approval</h3>

    <% if (!selected) { %>
      <div class="muted">Select an approval from the queue.</div>
    <% } else { %>

      <div class="summary-card">
        <div class="summary-row">
          <span class="pill"><b>ID</b>: <span class="muted"><%= selected.approval_id %></span></span>
          <span class="pill"><b>Status</b>: <span class="muted"><%= selected.decision_state || "PENDING" %></span></span>
          <span class="pill"><b>Gate</b>: <span class="muted"><%= selected.gate?.decision || "" %></span></span>
          <% if (selected.created_at) { %>
            <span class="pill"><b>Created</b>: <span class="muted"><%= selected.created_at %></span></span>
          <% } %>
        </div>

        <div style="margin-top:10px; display:flex; gap:10px; flex-wrap:wrap;">
          <a href="/approvals/<%= selected.approval_id %>/evidence.zip">
            <button type="button">Download Approval Evidence (ZIP)</button>
          </a>
        </div>
      </div>

      <% if (selected.apply_feedback_validate) { %>
        <div class="summary-card">
          <b>Apply+Validate Summary</b>
          <div class="summary-row" style="margin-top:8px;">
            <% const pass = !!selected.apply_feedback_validate.pass; %>
            <span class="pill"><b>PASS</b>: <span class="muted"><%= pass ? "true" : "false" %></span></span>
            <% if (selected.apply_feedback_validate.evaluated_count !== undefined) { %>
              <span class="pill"><b>evaluated</b>: <span class="muted"><%= selected.apply_feedback_validate.evaluated_count %></span></span>
            <% } %>
            <% if (selected.apply_feedback_validate.failed_steps) { %>
              <span class="pill"><b>failed</b>: <span class="muted"><%= selected.apply_feedback_validate.failed_steps.length %></span></span>
            <% } %>
          </div>
          <details style="margin-top:10px;">
            <summary class="muted">Show full result JSON</summary>
            <pre><%= JSON.stringify(selected.apply_feedback_validate, null, 2) %></pre>
          </details>
        </div>
      <% } %>

      <% if (selected && selected.decision_state === "APPROVED") { %>
        <form method="post" action="/approvals/<%= selected.approval_id %>/ask_master" class="btnrow">
          <div>
            <label>Provider</label><br/>
            <select name="provider">
              <option value="ollama">ollama (internal)</option>
              <option value="openai">openai (external)</option>
              <option value="anthropic">anthropic (external)</option>
            </select>
          </div>
          <div>
            <button type="submit">Call Master</button>
          </div>
        </form>

        <form method="post" action="/approvals/<%= selected.approval_id %>/apply_feedback_and_validate" class="btnrow">
          <div class="two">
            <div>
              <label>Max Commands</label>
              <input type="number" name="max_commands" value="6" min="1" max="20" />
            </div>
            <div>
              <label>Timeout (sec)</label>
              <input type="number" name="timeout_s" value="60" min="5" max="600" />
            </div>
          </div>
          <div>
            <label>Actor</label>
            <input type="text" name="actor" value="system" />
          </div>
          <div>
            <label class="small"><input type="checkbox" name="stop_on_fail" checked /> stop on fail</label><br/>
            <button type="submit">Apply + Validate (closed loop)</button>
          </div>
        </form>
      <% } %>

      <% if (selected.decision_state === "PENDING") { %>
        <form method="post" action="/approvals/<%= selected.approval_id %>/decide" class="btnrow">
          <div style="flex:1; min-width:160px;">
            <label>Actor</label>
            <input type="text" name="actor" value="admin" />
          </div>
          <div style="flex:2; min-width:240px;">
            <label>Reason</label>
            <input type="text" name="reason" value="Looks OK" />
          </div>
          <div>
            <label>Decision</label><br/>
            <select name="decision">
              <option value="approve">approve</option>
              <option value="reject">reject</option>
            </select>
          </div>
          <div>
            <button type="submit">Submit Decision</button>
          </div>
        </form>
      <% } %>

      <details style="margin-top:12px;">
        <summary class="muted">Show Selected Approval JSON (large)</summary>
        <pre><%= JSON.stringify(selected, null, 2) %></pre>
      </details>

    <% } %>
  </div>

  <script>
    (function(){

      // ---- M3-2 UI auth: token/actor stored in localStorage + cookie ----
      function setCookie(name, value){
        const v = encodeURIComponent(value || "");
        // 7 days
        document.cookie = `${name}=${v}; Path=/; Max-Age=${7*24*3600}`;
      }
      function delCookie(name){
        document.cookie = `${name}=; Path=/; Max-Age=0`;
      }
      const tokenEl = document.getElementById("authToken");
      const actorEl = document.getElementById("authActor");
      const saveBtn = document.getElementById("authSave");
      const clearBtn = document.getElementById("authClear");
      const statusEl = document.getElementById("authStatus");

      function loadAuth(){
        const t = localStorage.getItem("opsclaw_token") || "";
        const a = localStorage.getItem("opsclaw_actor") || "";
        if (tokenEl) tokenEl.value = t;
        if (actorEl) actorEl.value = a;
        if (statusEl) statusEl.textContent = t ? "token: set" : "token: empty";
      }
      function saveAuth(){
        const t = (tokenEl && tokenEl.value) ? tokenEl.value.trim() : "";
        const a = (actorEl && actorEl.value) ? actorEl.value.trim() : "";
        localStorage.setItem("opsclaw_token", t);
        localStorage.setItem("opsclaw_actor", a);
        setCookie("opsclaw_token", t);
        setCookie("opsclaw_actor", a);
        if (statusEl) statusEl.textContent = t ? "token: set" : "token: empty";
        // reload to ensure server-rendered POSTs include cookie
        location.reload();
      }
      function clearAuth(){
        localStorage.removeItem("opsclaw_token");
        localStorage.removeItem("opsclaw_actor");
        delCookie("opsclaw_token");
        delCookie("opsclaw_actor");
        if (statusEl) statusEl.textContent = "token: empty";
        location.reload();
      }
      if (saveBtn) saveBtn.addEventListener("click", saveAuth);
      if (clearBtn) clearBtn.addEventListener("click", clearAuth);
      loadAuth();

      const list = document.getElementById("approvalList");
      if (!list) return;

      const statusSel = document.getElementById("qStatus");
      const sortSel = document.getElementById("qSort");
      const searchInp = document.getElementById("qSearch");
      const resetBtn = document.getElementById("qReset");
      const countEl = document.getElementById("qCount");

      const pendingEl = document.getElementById("pendingCount");
      const btnPendingOnly = document.getElementById("btnPendingOnly");
      const btnNewest = document.getElementById("btnNewest");

      const selCountEl = document.getElementById("selCount");
      const btnSelectVisible = document.getElementById("btnSelectVisible");
      const btnClearSel = document.getElementById("btnClearSel");

      const bulkActor = document.getElementById("bulkActor");
      const bulkReason = document.getElementById("bulkReason");
      const btnBulkApprove = document.getElementById("btnBulkApprove");
      const btnBulkReject = document.getElementById("btnBulkReject");
      const bulkMsg = document.getElementById("bulkMsg");

      const items = Array.from(list.querySelectorAll("li"));

      function parseTs(iso){
        if (!iso) return 0;
        const t = Date.parse(iso);
        return isNaN(t) ? 0 : t;
      }

      function pickedIds(){
        return Array.from(document.querySelectorAll(".qPick:checked")).map(x => x.value);
      }
      function updateSel(){
        if (selCountEl) selCountEl.textContent = String(pickedIds().length);
      }

      function apply(){
        const st = (statusSel && statusSel.value) ? statusSel.value : "ALL";
        const sort = (sortSel && sortSel.value) ? sortSel.value : "PENDING_FIRST";
        const q = (searchInp && searchInp.value) ? searchInp.value.trim().toLowerCase() : "";

        let visible = items.filter(li => {
          const s = li.dataset.status || "";
          const title = li.dataset.title || "";
          const id = li.dataset.id || "";
          if (st !== "ALL" && s !== st) return false;
          if (q) {
            if (!title.includes(q) && !id.toLowerCase().includes(q)) return false;
          }
          return true;
        });

        visible.sort((a,b) => {
          const aSt = a.dataset.status || "";
          const bSt = b.dataset.status || "";
          const aTs = parseTs(a.dataset.created || "");
          const bTs = parseTs(b.dataset.created || "");
          const aTitle = a.dataset.title || "";
          const bTitle = b.dataset.title || "";

          if (sort === "PENDING_FIRST") {
            if (aSt === "PENDING" && bSt !== "PENDING") return -1;
            if (bSt === "PENDING" && aSt !== "PENDING") return 1;
            return bTs - aTs;
          }
          if (sort === "NEWEST") return bTs - aTs;
          if (sort === "OLDEST") return aTs - bTs;
          if (sort === "TITLE") return aTitle.localeCompare(bTitle);
          return 0;
        });

        items.forEach(li => li.style.display = "none");
        visible.forEach(li => li.style.display = "");
        visible.forEach(li => list.appendChild(li));

        if (countEl) countEl.textContent = `Showing ${visible.length} / ${items.length}`;

        if (pendingEl) {
          const pending = visible.filter(li => (li.dataset.status || "") === "PENDING").length;
          pendingEl.textContent = String(pending);
        }

        updateSel();
      }

      function reset(){
        if (statusSel) statusSel.value = "ALL";
        if (sortSel) sortSel.value = "PENDING_FIRST";
        if (searchInp) searchInp.value = "";
        apply();
      }

      async function bulkDecide(decision){
        const ids = pickedIds();
        if (!ids.length) { if (bulkMsg) bulkMsg.textContent = "No items selected."; return; }
        if (bulkMsg) bulkMsg.textContent = `Submitting ${ids.length}...`;

        const payload = {
          approval_ids: ids,
          decision,
          actor: (bulkActor && bulkActor.value) ? bulkActor.value : "admin",
          reason: (bulkReason && bulkReason.value) ? bulkReason.value : ""
        };

        const r = await fetch("/approvals/bulk_decide", {
          headers: (function(){
            const h = {"content-type":"application/json"};
            const t = (localStorage.getItem("opsclaw_token")||"").trim();
            const a = (localStorage.getItem("opsclaw_actor")||"").trim();
            if (t) h["x-opsclaw-token"] = t;
            if (a) h["x-opsclaw-actor"] = a;
            return h;
          })(),
          method: "POST",
          body: JSON.stringify(payload),
        });

        const txt = await r.text();
        if (!r.ok) { if (bulkMsg) bulkMsg.textContent = `ERROR ${r.status}: ${txt}`; return; }
        if (bulkMsg) bulkMsg.textContent = "Done. Refreshing...";
        setTimeout(() => location.reload(), 600);
      }

      document.addEventListener("change", (e) => {
        const t = e.target;
        if (t && t.classList && t.classList.contains("qPick")) updateSel();
      });

      if (statusSel) statusSel.addEventListener("change", apply);
      if (sortSel) sortSel.addEventListener("change", apply);
      if (searchInp) searchInp.addEventListener("input", apply);
      if (resetBtn) resetBtn.addEventListener("click", reset);

      if (btnPendingOnly) btnPendingOnly.addEventListener("click", () => {
        if (statusSel) statusSel.value = "PENDING";
        apply();
      });

      if (btnNewest) btnNewest.addEventListener("click", () => {
        if (sortSel) sortSel.value = "NEWEST";
        apply();
      });

      if (btnSelectVisible) btnSelectVisible.addEventListener("click", () => {
        // select all currently visible
        items.forEach(li => {
          if (li.style.display === "none") return;
          const cb = li.querySelector(".qPick");
          if (cb) cb.checked = true;
        });
        updateSel();
      });

      if (btnClearSel) btnClearSel.addEventListener("click", () => {
        document.querySelectorAll(".qPick:checked").forEach(x => x.checked=false);
        updateSel();
      });

      if (btnBulkApprove) btnBulkApprove.addEventListener("click", () => bulkDecide("approve"));
      if (btnBulkReject) btnBulkReject.addEventListener("click", () => bulkDecide("reject"));

      apply();
    })();
  </script>
</body>
</html>
