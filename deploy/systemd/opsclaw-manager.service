[Unit]
Description=OpsClaw Manager API
After=network.target postgresql.service

[Service]
ExecStart=python3 -m uvicorn apps.manager-api.src.main:app --host 0.0.0.0 --port 8000
WorkingDirectory=/opt/opsclaw
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal
EnvironmentFile=/opt/opsclaw/.env

[Install]
WantedBy=multi-user.target
